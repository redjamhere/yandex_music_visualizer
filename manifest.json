{
  "manifest_version": 3,
  "name": "Yandex Audio Hijacker",
  "version": "5.0",
  "permissions": ["declarativeNetRequest"],
  "host_permissions": ["https://*.yandex.net/*", "https://*.yandex.ru/*"],
  "declarative_net_request": {
    "rule_resources": [{
      "id": "ruleset_1",
      "enabled": true,
      "path": "rules.json"
    }]
  },
  "content_scripts": [
    {
      "matches": ["https://music.yandex.ru/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}